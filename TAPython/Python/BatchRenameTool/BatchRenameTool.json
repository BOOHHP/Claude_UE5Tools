{
  "TabLabel": "批量重命名工具",
  "InitTabSize": [560, 420],
  "InitPyCmd": "import importlib; from BatchRenameTool import BatchRenameTool; importlib.reload(BatchRenameTool); BatchRenameTool.instance = BatchRenameTool.BatchRenameController(%JsonPath)",
  "Root": {
    "SScrollBox": {
      "Slots": [
        {
          "Padding": 15,
          "SVerticalBox": {
            "Slots": [
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 15],
                "SHorizontalBox": {
                  "Slots": [
                    {
                      "AutoWidth": true,
                      "VAlign": "VAlign_Center",
                      "STextBlock": {
                        "Text": "资源前缀："
                      }
                    },
                    {
                      "FillWidth": 1.0,
                      "Padding": [10, 0, 0, 0],
                      "SEditableTextBox": {
                        "Aka": "input_prefix",
                        "Text": "SM_"
                      }
                    }
                  ]
                }
              },
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 15],
                "SHorizontalBox": {
                  "Slots": [
                    {
                      "AutoWidth": true,
                      "Padding": [0, 0, 20, 0],
                      "SCheckBox": {
                        "Aka": "chk_skip_prefixed",
                        "IsChecked": true,
                        "Content": {
                          "STextBlock": {
                            "Text": "跳过已有前缀的资源"
                          }
                        }
                      }
                    },
                    {
                      "AutoWidth": true,
                      "SCheckBox": {
                        "Aka": "chk_auto_conflict",
                        "IsChecked": true,
                        "Content": {
                          "STextBlock": {
                            "Text": "冲突时自动添加后缀"
                          }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 15],
                "SHorizontalBox": {
                  "Slots": [
                    {
                      "FillWidth": 1.0,
                      "Padding": [0, 0, 8, 0],
                      "SButton": {
                        "Aka": "btn_preview",
                        "HAlign": "HAlign_Center",
                        "ContentPadding": [20, 5],
                        "Text": "预览",
                        "OnClick": "BatchRenameTool.instance.preview_rename()"
                      }
                    },
                    {
                      "FillWidth": 1.0,
                      "SButton": {
                        "Aka": "btn_execute",
                        "HAlign": "HAlign_Center",
                        "ContentPadding": [20, 5],
                        "Text": "执行重命名",
                        "OnClick": "BatchRenameTool.instance.execute_rename()"
                      }
                    }
                  ]
                }
              },
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 15],
                "SBorder": {
                  "Padding": 8,
                  "BorderImage": {
                    "Style": "FCoreStyle",
                    "Brush": "ToolPanel.GroupBorder"
                  },
                  "Content": {
                    "SMultiLineEditableTextBox": {
                      "Aka": "txt_preview",
                      "Text": "预览结果将显示在此处",
                      "IsReadOnly": true,
                      "AutoWrapText": false,
                      "SelectAllTextWhenFocused": false
                    }
                  }
                }
              },
              {
                "AutoHeight": true,
                "SBorder": {
                  "Padding": 10,
                  "BorderImage": {
                    "Style": "FCoreStyle",
                    "Brush": "ToolPanel.GroupBorder"
                  },
                  "Content": {
                    "STextBlock": {
                      "Aka": "txt_status",
                      "Text": "准备完毕。在内容浏览器中选择资源并预览更改。",
                      "ColorAndOpacity": [0.7, 0.7, 0.7, 1.0]
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    }
  }
}

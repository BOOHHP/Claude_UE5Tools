{
    "TabLabel": "场景选择工具",
    "InitTabSize": [360, 530],
    "InitPyCmd": "import importlib; from SceneSelectTool import SceneSelectTool; importlib.reload(SceneSelectTool); SceneSelectTool.instance = SceneSelectTool.SceneSelectController(%JsonPath)",

    "Root": {
        "SScrollBox": {
            "Slots": [
                {
                    "Padding": [12, 12, 12, 4],
                    "SVerticalBox": {
                        "Slots": [

                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 6],
                                "STextBlock": {
                                    "Text": "选择范围",
                                    "Font": ["Segoe UI", "11", "Bold"],
                                    "ColorAndOpacity": [0.9, 0.9, 0.9, 1.0]
                                }
                            },
                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 10],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "AutoWidth": true,
                                            "Padding": [0, 0, 6, 0],
                                            "SCheckBox": {
                                                "Aka": "chk_scope_current",
                                                "IsChecked": true,
                                                "CheckBoxStyle": {
                                                    "Style": "FCoreStyle",
                                                    "StyleName": "Menu.ToggleButton"
                                                },
                                                "Padding": [10, 4],
                                                "Content": {
                                                    "STextBlock": {
                                                        "Text": "当前关卡",
                                                        "Justification": "Center"
                                                    }
                                                },
                                                "OnCheckStateChanged": "SceneSelectTool.instance.on_scope_current_changed(%)"
                                            }
                                        },
                                        {
                                            "AutoWidth": true,
                                            "SCheckBox": {
                                                "Aka": "chk_scope_all",
                                                "IsChecked": false,
                                                "CheckBoxStyle": {
                                                    "Style": "FCoreStyle",
                                                    "StyleName": "Menu.ToggleButton"
                                                },
                                                "Padding": [10, 4],
                                                "Content": {
                                                    "STextBlock": {
                                                        "Text": "所有关卡",
                                                        "Justification": "Center"
                                                    }
                                                },
                                                "OnCheckStateChanged": "SceneSelectTool.instance.on_scope_all_changed(%)"
                                            }
                                        }
                                    ]
                                }
                            },

                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 10],
                                "SSeparator": {
                                    "Orientation": "Horizontal",
                                    "Thickness": 1.0
                                }
                            },

                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 6],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "VAlign": "VAlign_Center",
                                            "STextBlock": {
                                                "Text": "物件类型",
                                                "Font": ["Segoe UI", "11", "Bold"],
                                                "ColorAndOpacity": [0.9, 0.9, 0.9, 1.0]
                                            }
                                        },
                                        {
                                            "AutoWidth": true,
                                            "Padding": [0, 0, 4, 0],
                                            "SButton": {
                                                "Aka": "btn_select_all",
                                                "ContentPadding": [8, 2],
                                                "Text": "全选",
                                                "OnClick": "SceneSelectTool.instance.select_all_types(True)"
                                            }
                                        },
                                        {
                                            "AutoWidth": true,
                                            "SButton": {
                                                "Aka": "btn_deselect_all",
                                                "ContentPadding": [8, 2],
                                                "Text": "全不选",
                                                "OnClick": "SceneSelectTool.instance.select_all_types(False)"
                                            }
                                        }
                                    ]
                                }
                            },

                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 4],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "Padding": [0, 0, 4, 0],
                                            "SCheckBox": {
                                                "Aka": "chk_static_mesh",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  静态网格体" } }
                                            }
                                        },
                                        {
                                            "FillWidth": 1.0,
                                            "SCheckBox": {
                                                "Aka": "chk_blueprint",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  蓝图" } }
                                            }
                                        }
                                    ]
                                }
                            },
                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 4],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "Padding": [0, 0, 4, 0],
                                            "SCheckBox": {
                                                "Aka": "chk_point_light",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  点光源" } }
                                            }
                                        },
                                        {
                                            "FillWidth": 1.0,
                                            "SCheckBox": {
                                                "Aka": "chk_spot_light",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  聚光灯" } }
                                            }
                                        }
                                    ]
                                }
                            },
                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 4],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "Padding": [0, 0, 4, 0],
                                            "SCheckBox": {
                                                "Aka": "chk_dir_light",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  方向光" } }
                                            }
                                        },
                                        {
                                            "FillWidth": 1.0,
                                            "SCheckBox": {
                                                "Aka": "chk_rect_light",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  矩形光" } }
                                            }
                                        }
                                    ]
                                }
                            },
                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 4],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "Padding": [0, 0, 4, 0],
                                            "SCheckBox": {
                                                "Aka": "chk_sky_light",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  天空光" } }
                                            }
                                        },
                                        {
                                            "FillWidth": 1.0,
                                            "SCheckBox": {
                                                "Aka": "chk_decal",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  贴花" } }
                                            }
                                        }
                                    ]
                                }
                            },
                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 10],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "Padding": [0, 0, 4, 0],
                                            "SCheckBox": {
                                                "Aka": "chk_camera",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  摄像机" } }
                                            }
                                        },
                                        {
                                            "FillWidth": 1.0,
                                            "SCheckBox": {
                                                "Aka": "chk_trigger",
                                                "IsChecked": false,
                                                "Content": { "STextBlock": { "Text": "  触发器" } }
                                            }
                                        }
                                    ]
                                }
                            },

                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 10],
                                "SSeparator": {
                                    "Orientation": "Horizontal",
                                    "Thickness": 1.0
                                }
                            },

                            {
                                "AutoHeight": true,
                                "Padding": [0, 0, 0, 10],
                                "SHorizontalBox": {
                                    "Slots": [
                                        {
                                            "FillWidth": 1.0,
                                            "Padding": [0, 0, 6, 0],
                                            "SButton": {
                                                "Aka": "btn_execute",
                                                "HAlign": "HAlign_Center",
                                                "ContentPadding": [30, 8],
                                                "Text": "批量选择",
                                                "OnClick": "SceneSelectTool.instance.execute_select()"
                                            }
                                        },
                                        {
                                            "FillWidth": 1.0,
                                            "SButton": {
                                                "Aka": "btn_clear_selection",
                                                "HAlign": "HAlign_Center",
                                                "ContentPadding": [30, 8],
                                                "Text": "取消所有选择",
                                                "OnClick": "SceneSelectTool.instance.clear_selection()"
                                            }
                                        }
                                    ]
                                }
                            },

                            {
                                "AutoHeight": true,
                                "SBorder": {
                                    "Padding": 10,
                                    "BorderImage": {
                                        "Style": "FCoreStyle",
                                        "Brush": "ToolPanel.GroupBorder"
                                    },
                                    "Content": {
                                        "STextBlock": {
                                            "Aka": "txt_status",
                                            "Text": "就绪。请选择范围和物件类型后点击批量选择。",
                                            "ColorAndOpacity": [0.7, 0.7, 0.7, 1.0],
                                            "AutoWrapText": true
                                        }
                                    }
                                }
                            }

                        ]
                    }
                }
            ]
        }
    }
}
